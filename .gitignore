# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.open-next/
/out/

# cloudflare/wrangler (local dev state)
.wrangler/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets stay local; committed *.example templates are allowed)
.env*
!.env.example
!.env.development.example
!.env.staging.example
!.env.production.example
!.dev.vars.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
