# Environment templates for this repo (no secrets here).
#
# Next.js loads files in this order (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables):
#   .env
#   .env.local                    (override; gitignored — put secrets here)
#   .env.development / .env.production  (based on NODE_ENV)
#   .env.development.local / .env.production.local
#
# Staging is not a built-in Next mode. Use `.env.staging` plus npm scripts that run
# `dotenv-cli` before `opennextjs-cloudflare build` (see package.json).
#
# Copy the file you need:
#   cp .env.development.example .env.development.local
#   cp .env.staging.example      .env.staging
#   cp .env.production.example   .env.production.local
#
# Wrangler local preview (`npm run preview:worker`) can use `.dev.vars` for Worker-only
# secrets (gitignored). See `.dev.vars.example`.
